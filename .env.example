# Citévision v2 Environment Configuration
# Copy to .env and adjust values for your environment (NO secrets in git)
# start-windows.ps1 auto-generates secrets if .env is missing

APP_ENV=development
APP_NAME=citevision-v2
LOG_LEVEL=info

# --- API Backend (v2 port 8081) ---
API_HOST=0.0.0.0
API_PORT=8081
JWT_SECRET=changeme_jwt_secret_min_16_chars
JWT_ACCESS_TTL=15m
# Dev long sessions: JWT_ACCESS_TTL=8h
JWT_REFRESH_TTL=168h
AUDIT_SIGNING_KEY=changeme_audit_signing_key_32
CAMERA_CREDENTIAL_KEY=changeme_camera_credential_key_32bytes_min

# --- PostgreSQL (v2 port 5433) ---
POSTGRES_USER=citevision
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=citevision
POSTGRES_PORT=5433
POSTGRES_HOST=localhost
DATABASE_URL=postgresql://citevision:changeme_postgres@localhost:5433/citevision

# --- Redis (v2 port 6380) ---
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380/0

# --- MQTT Mosquitto (v2 port 1884) ---
MQTT_HOST=localhost
MQTT_PORT=1884
MQTT_WS_PORT=9002
MQTT_BROKER=tcp://localhost:1884
MQTT_USERNAME=
MQTT_PASSWORD=

# --- MinIO (v2 ports 9003 API / 9004 console) ---
MINIO_ROOT_USER=citevision
MINIO_ROOT_PASSWORD=changeme_minio
MINIO_API_PORT=9003
MINIO_CONSOLE_PORT=9004
MINIO_ENDPOINT=http://localhost:9003
MINIO_ACCESS_KEY=citevision
MINIO_SECRET_KEY=changeme_minio
MINIO_BUCKET=citevision-evidence
PUBLIC_API_BASE=http://localhost:8081/api/v1

# --- Email / SMTP (demo uses MailHog: SMTP :1025, web UI :8025) ---
# For real delivery set SMTP_HOST/PORT/USER/PASS/FROM and SMTP_USE_TLS=true.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alertes@citevision.local
SMTP_USE_TLS=false
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
# Public URL of the MailHog inbox, surfaced in the demo UI + email footer.
MAILHOG_PUBLIC_URL=http://localhost:8025

# --- AI Engine (v2 port 8001) ---
AI_ENGINE_HOST=0.0.0.0
AI_ENGINE_PORT=8001
# Set to 1 to skip AI ingest retries when AI engine is down (reduces backend load).
# DISABLE_AI_INGEST=1
YOLO_MODEL_PATH=models/yolov8n.onnx
MAX_CAMERAS=12
YOLO_CONFIDENCE=0.25
YOLO_IOU=0.45

# Frigate evidence (off by default — mirrors root .env FRIGATE_*)
FRIGATE_ENABLED=0
FRIGATE_LIVE=0
FRIGATE_EVIDENCE=0
FRIGATE_URL=http://127.0.0.1:5000
EVIDENCE_BACKEND=ring_buffer

# --- Video storage (neutral install — upload via Demo Center) ---
VIDEOS_PATH=data/videos
DEMO_VIDEO_PATH=
PROJECT_ROOT=

# --- Rules Engine ---
RULES_ENGINE_HOST=0.0.0.0
RULES_ENGINE_PORT=8010
RULES_DEDUP_TTL_SEC=60
BACKEND_API_URL=http://localhost:8081
DEFAULT_ORG_ID=
INTERNAL_API_KEY=changeme_internal_service_key

# --- Video Engine (v2 health port 9011) ---
RTSP_URL=rtsp://127.0.0.1:8554/stream
VIDEO_ENGINE_HEALTH_PORT=9011
ANALYSIS_WIDTH=640
ANALYSIS_HEIGHT=480
RECORD_WIDTH=1280
RECORD_HEIGHT=720
TARGET_FPS=5

# --- go2rtc (v2 port 1984) ---
GO2RTC_URL=http://localhost:1984
GO2RTC_PORT=1984

# --- Frigate (media plane: live bbox, record, evidence export) ---
FRIGATE_ENABLED=0
FRIGATE_CONFIG_SYNC=0
FRIGATE_LIVE=0
FRIGATE_EVIDENCE=0
FRIGATE_EVENTS=0
FRIGATE_URL=http://127.0.0.1:5000
FRIGATE_CONFIG_PATH=infra/frigate-config/config.yml
FRIGATE_PORT=5000
# ring_buffer | frigate | hybrid
# Use "hybrid" when Frigate is enabled: tries Frigate clip first, falls back to
# ring buffer so alerts are NEVER suppressed due to a missing Frigate clip.
# Pure "frigate" disables the ring buffer and causes "alert suppressed: incomplete
# evidence" whenever Frigate has no ready clip — do NOT use in production.
EVIDENCE_BACKEND=hybrid
DEMO_MODE=0
DEMO_EVIDENCE_BACKEND=strict_frigate
DEMO_RESOLUTION=1080p
# Live camera 108 ingest is gated until demo E2E is stable (set to 1 after FPS check).
LIVE_108_ENABLED=0
# Frigate track evidence retries (mirrors citevision_videoverbalisation mono/)
FRIGATE_EVENT_MATCH_SEC=12
FRIGATE_SNAPSHOT_RETRIES=8
FRIGATE_CLIP_RETRIES=8
FRIGATE_CLIP_MIN_BYTES=512
FRIGATE_EVIDENCE_FRAME_COUNT=6
FRIGATE_CLIP_FRAME_JPEG_Q=2

# Demo retention — Frigate recordings + MinIO evidence (minutes)
FRIGATE_DEMO_RETENTION_MIN=30
# Fast-ALPR OCR service (docker compose --profile ocr up citevision-ocr)
OCR_URL=http://127.0.0.1:8181/ocr
OCR_TIMEOUT=8
PLATE_MAX_FRAMES=6
PLATE_STOP_CONF=0.88
PLATE_MIN_CONF=0.35

# Frontend mirrors (Vite) — keep 0 until Frigate sidecar is running
VITE_FRIGATE_ENABLED=0
VITE_FRIGATE_LIVE=0

# --- Camera test (local .env only, never commit real password) ---
CAMERA_TEST_IP=192.168.1.108
CAMERA_TEST_USER=admin
CAMERA_TEST_PASSWORD=

# --- Optional models (leave empty to disable gracefully) ---
INSIGHTFACE_MODEL_PATH=
PADDLEOCR_MODEL_DIR=

# --- Security hardening (citevision_optimized) ---
# Required at boot; MUST be changed from the placeholder outside development.
INTERNAL_API_KEY=changeme_internal_service_key
# Comma-separated browser origin allowlist for CORS. Empty = localhost dev only.
# Use "*" to allow any origin (no credentials).
CORS_ALLOWED_ORIGINS=
# WebSocket upgrade origin allowlist. Empty reuses the CORS dev defaults.
WS_ALLOWED_ORIGINS=
# Postgres TLS mode (disable|require|verify-full). Default: disable (dev).
POSTGRES_SSLMODE=disable
# Expose /metrics without the internal key (only behind a trusted proxy).
METRICS_PUBLIC=0
# Outbound webhook SSRF controls. By default private/loopback/metadata targets
# are blocked. Self-hosted n8n/Make on the LAN:
WEBHOOK_ALLOW_PRIVATE=0
WEBHOOK_ALLOWED_HOSTS=
# HMAC-SHA256 secret used to sign outbound webhooks (X-CiteVision-Signature).
WEBHOOK_SIGNING_SECRET=
