# Citévision 2.0 Environment Configuration
# Copy to .env and adjust values for your environment

APP_ENV=development
APP_NAME=citevision
LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=8080

# --- Auth / Security (required) ---
JWT_SECRET=citevision_jwt_dev_secret_min_32_chars!!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
AUDIT_SIGNING_KEY=citevision_audit_hmac_key_dev_32b!!
CAMERA_CREDENTIAL_KEY=citevision_camera_aes_key_32bytes!!

# --- Seed admin (first run) ---
SEED_ADMIN_EMAIL=admin@citevision.local
SEED_ADMIN_PASSWORD=Citevision123!
SEED_TENANT_NAME=Citevision Demo
SEED_TENANT_SLUG=demo

# --- PostgreSQL ---
POSTGRES_USER=citevision
POSTGRES_PASSWORD=citevision_dev_change_me
POSTGRES_DB=citevision
POSTGRES_PORT=5432
POSTGRES_HOST=localhost
DATABASE_URL=postgresql://citevision:citevision_dev_change_me@localhost:5432/citevision

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- MQTT (Mosquitto) ---
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_WS_PORT=9001
MQTT_BROKER=tcp://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=cv/detections

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=citevision
MINIO_ROOT_PASSWORD=citevision_minio_dev_change_me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9090
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=citevision-evidence
MINIO_ACCESS_KEY=citevision
MINIO_SECRET_KEY=citevision_minio_dev_change_me

# --- AI Engine ---
AI_ENGINE_HOST=0.0.0.0
AI_ENGINE_PORT=8000
YOLO_MODEL_PATH=ai-engine/models/yolov8n.onnx
CITEVISION_MODEL_PATH=ai-engine/models/yolov8n.onnx
YOLO_CONFIDENCE=0.45
AI_CONFIDENCE_THRESHOLD=0.5
YOLO_IOU=0.5
MAX_CAMERAS=12
DEFAULT_CAMERA_ID=cam-001

# --- Video Engine ---
RTSP_URL=rtsp://localhost:8554/stream
CAMERA_ID=cam-001
VIDEO_ENGINE_PORT=9010
CITEVISION_HEALTH_PORT=9010
HEALTH_PORT=9010
ANALYSIS_WIDTH=640
ANALYSIS_HEIGHT=480
RECORD_WIDTH=1280
RECORD_HEIGHT=720
TARGET_FPS=5
RECORDINGS_PATH=data/recordings

# --- Notifications (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@citevision.local
SMS_WEBHOOK_URL=

# --- GitHub (private repo — replace before push) ---
GITHUB_PAT=ghp_PLACEHOLDER_DO_NOT_USE_REAL_TOKEN
GITHUB_REPO=henockglory/Cityvision-version2.0

# --- Test camera (env only — never hardcode in source) ---
TEST_CAMERA_IP=192.168.1.108
TEST_CAMERA_USER=admin
TEST_CAMERA_PASSWORD=hids+1234

# --- External placeholders ---
OPENAI_API_KEY=sk-PLACEHOLDER_DO_NOT_USE_REAL_KEY
WEBHOOK_SECRET=whsec_PLACEHOLDER
