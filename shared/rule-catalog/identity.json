[
  {
    "id": "tpl-watchlist-match",
    "name": "Visage liste de surveillance",
    "category": "identity",
    "severity": "critical",
    "definition": {
      "condition": {
        "op": "eq",
        "field": "event_type",
        "value": "face_watchlist_match"
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "critical"
          }
        },
        {
          "type": "record",
          "config": {
            "duration_sec": 60
          }
        }
      ]
    }
