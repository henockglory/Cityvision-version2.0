  {
    "id": "tpl-zone-presence",
    "name": "Présence dans une zone",
    "description": "Objet présent dans une zone définie",
    "category": "presence",
    "severity": "low",
    "definition": {
      "condition": {
        "op": "AND",
        "children": [
          {
            "op": "eq",
            "field": "event_type",
            "value": "zone_presence"
          },
          {
            "op": "eq",
            "field": "zone_id",
            "value": "__ZONE__"
          },
          {
            "op": "matches_class",
            "field": "class_name",
            "value": "person"
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "low"
          }
        }
      ]
    },
    "role_summary_fr": "Vérifie en continu la présence d'un objet dans la zone et alerte si la condition est remplie.",
    "deployment_scopes": [
      "enterprise",
      "domestic"
    ],
    "partial_status": "full"
  },
  {
    "id": "tpl-zone-absence",
    "name": "Absence prolongée dans une zone",
    "description": "Absence attendue non respectée dans une zone sensible",
    "category": "presence",
    "severity": "medium",
    "definition": {
      "condition": {
        "op": "AND",
        "children": [
          {
            "op": "eq",
            "field": "event_type",
            "value": "zone_absence"
          },
          {
            "op": "eq",
            "field": "zone_id",
            "value": "__ZONE__"
          },
          {
            "op": "matches_class",
            "field": "class_name",
            "value": "person"
          },
          {
            "op": "gt",
            "field": "duration_seconds",
            "value": 300
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "medium"
          }
        }
      ]
    },
    "role_summary_fr": "Alerte si la zone est vide alors qu'elle devrait être occupée (ex. poste de garde abandonné).",
    "deployment_scopes": [
      "enterprise",
      "domestic"
    ],
    "partial_status": "full"
  },
  {
    "id": "tpl-immobility",
    "name": "Immobilité prolongée",
    "description": "Objet ou personne immobile trop longtemps",
    "category": "presence",
    "severity": "medium",
    "definition": {
      "condition": {
        "op": "ET",
        "children": [
          {
            "op": "eq",
            "field": "event_type",
            "value": "stationary"
          },
          {
            "op": "gt",
            "field": "duration_seconds",
            "value": 90
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "medium"
          }
        }
      ]
    },
    "role_summary_fr": "Alerte si une personne reste totalement immobile — peut indiquer un malaise ou un abandon de poste.",
    "deployment_scopes": [
      "enterprise",
      "domestic"
    ],
    "partial_status": "full"
  },
  {
    "id": "tpl-erratic-motion",
    "name": "Mouvement erratique",
    "description": "Changements de direction brusques répétés",
    "category": "presence",
    "severity": "high",
    "definition": {
      "condition": {
        "op": "contains",
        "field": "metadata.behavior",
        "value": "erratic"
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "high"
          }
        }
      ]
    },
    "role_summary_fr": "Détecte les mouvements désordonnés ou imprévisibles — comportement inhabituel dans un lieu public.",
    "deployment_scopes": [
      "enterprise",
      "domestic"
    ],
    "partial_status": "full"
  },
  {
    "id": "tpl-wandering",
    "name": "Errance prolongée",
    "description": "Trajet non linéaire prolongé dans une zone",
    "category": "presence",
    "severity": "medium",
    "definition": {
      "condition": {
        "op": "contains",
        "field": "metadata.behavior",
        "value": "wandering"
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "medium"
          }
        }
      ]
    },
    "role_summary_fr": "Alerte quand une personne déambule sans trajectoire claire — peut signaler une personne désorientée.",
    "deployment_scopes": [
      "enterprise",
      "domestic"
    ],
    "partial_status": "partial_aggregate",
    "partial_reason_fr": "Errance détectée via heuristique wandering — nécessite activité continue ≥45s dans le champ"
  }
