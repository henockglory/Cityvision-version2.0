[
  {
    "id": "tpl-object-appeared",
    "name": "Apparition d'objet",
    "description": "Détecte l'apparition d'un nouvel objet dans la scène",
    "category": "presence",
    "severity": "low",
    "definition": {
      "condition": {
        "op": "eq",
        "field": "event_type",
        "value": "object_appeared"
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "low"
          }
        }
      ]
    },
    "role_summary_fr": "Alerte quand un nouvel objet apparaît dans la zone — dépôt non autorisé.",
    "deployment_scopes": [
      "enterprise",
      "domestic"
    ],
    "partial_status": "full"
  },
  {
    "id": "tpl-object-disappeared",
    "name": "Disparition d'objet",
    "description": "Détecte la disparition d'un objet précédemment visible",
    "category": "presence",
    "severity": "medium",
    "definition": {
      "condition": {
        "op": "eq",
        "field": "event_type",
        "value": "object_disappeared"
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "medium"
          }
        }
      ]
    },
    "role_summary_fr": "Détecte la disparition d'un objet présent dans la scène — vol ou déplacement suspect.",
    "deployment_scopes": [
      "enterprise",
      "domestic"
    ],
    "partial_status": "full"
  },
  {
    "id": "tpl-zone-presence",
    "name": "Présence dans une zone",
    "description": "Objet présent dans une zone définie",
    "category": "presence",
    "severity": "low",
    "definition": {
      "condition": {
        "op": "AND",
        "children": [
          {
            "op": "eq",
            "field": "event_type",
            "value": "zone_presence"
          },
          {
            "op": "eq",
            "field": "zone_id",
            "value": "__ZONE__"
          },
          {
            "op": "matches_class",
            "field": "class_name",
            "value": "person"
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "low"
          }
        }
      ]
    },
    "role_summary_fr": "Vérifie en continu la présence d'un objet dans la zone et alerte si la condition est remplie.",
    "deployment_scopes": [
      "enterprise",
      "domestic"
    ],
    "partial_status": "full"
  },
  {
    "id": "tpl-zone-absence",
    "name": "Absence prolongée dans une zone",
    "description": "Absence attendue non respectée dans une zone sensible",
    "category": "presence",
    "severity": "medium",
    "definition": {
      "condition": {
        "op": "AND",
        "children": [
          {
            "op": "eq",
            "field": "event_type",
            "value": "zone_absence"
          },
          {
            "op": "eq",
            "field": "zone_id",
            "value": "__ZONE__"
          },
          {
            "op": "matches_class",
            "field": "class_name",
            "value": "person"
          },
          {
            "op": "gt",
            "field": "duration_seconds",
            "value": 300
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "medium"
          }
        }
      ]
    },
    "role_summary_fr": "Alerte si la zone est vide alors qu'elle devrait être occupée (ex. poste de garde abandonné).",
    "deployment_scopes": [
      "enterprise",
      "domestic"
    ],
    "partial_status": "full"
  },
  {
    "id": "tpl-immobility",
    "redirect_to": "tpl-person-stopped",
    "_fusion_note": "[I.80] Doublon fusionné vers tpl-person-stopped. L'événement 'stationary' n'est jamais émis (analytics/behavior.py renvoie une heuristique interne, pas un événement) ; l'immobilité réelle est produite par 'person_stopped'/'vehicle_stopped' (state.py, basé sur la durée)."
  }
]
