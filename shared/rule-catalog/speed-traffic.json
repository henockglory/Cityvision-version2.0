[
  {
    "id": "tpl-speeding",
    "name": "Excès de vitesse véhicule",
    "description": "Véhicule dépassant le seuil de vitesse configuré",
    "category": "speed",
    "severity": "high",
    "definition": {
      "condition": {
        "op": "ET",
        "children": [
          {
            "op": "eq",
            "field": "class_name",
            "value": "car"
          },
          {
            "op": "gt",
            "field": "speed_kmh",
            "value": 50
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "high"
          }
        }
      ]
    },
    "role_summary_fr": "Alerte si un véhicule dépasse la vitesse limite configurée — nécessite calibration caméra.",
    "deployment_scopes": [
      "national",
      "enterprise"
    ],
    "partial_status": "requires_calibration",
    "partial_reason_fr": "Nécessite une calibration caméra (homographie) pour mesurer la vitesse en km/h"
  },
  {
    "id": "tpl-sudden-stop",
    "name": "Arrêt brusque",
    "description": "Décélération brutale détectée",
    "category": "speed",
    "severity": "medium",
    "definition": {
      "condition": {
        "op": "eq",
        "field": "event_type",
        "value": "sudden_stop"
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "medium"
          }
        }
      ]
    },
    "role_summary_fr": "Alerte quand un véhicule freine brusquement — indicateur d'accident ou de situation d'urgence.",
    "deployment_scopes": [
      "national",
      "enterprise"
    ],
    "partial_status": "requires_calibration",
    "partial_reason_fr": "Nécessite une calibration caméra pour détecter les variations de vitesse"
  },
  {
    "id": "tpl-running-person",
    "name": "Course / fuite",
    "description": "Personne en course rapide",
    "category": "speed",
    "severity": "high",
    "definition": {
      "condition": {
        "op": "ET",
        "children": [
          {
            "op": "eq",
            "field": "class_name",
            "value": "person"
          },
          {
            "op": "gt",
            "field": "speed_kmh",
            "value": 15
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "high"
          }
        }
      ]
    },
    "role_summary_fr": "Alerte quand une personne court — signal d'urgence ou de poursuite dans un espace protégé.",
    "deployment_scopes": [
      "national",
      "enterprise"
    ],
    "partial_status": "full"
  },
  {
    "id": "tpl-traffic-jam",
    "name": "Embouteillage",
    "description": "Densité élevée et vitesse faible prolongée",
    "category": "traffic",
    "severity": "warning",
    "definition": {
      "condition": {
        "op": "ET",
        "children": [
          {
            "op": "gt",
            "field": "metadata.vehicle_count",
            "value": 8
          },
          {
            "op": "lt",
            "field": "metadata.avg_speed_kmh",
            "value": 10
          },
          {
            "op": "gt",
            "field": "duration_seconds",
            "value": 120
          }
        ]
      },
      "actions": [
        {
          "type": "notify",
          "config": {
            "channel": "ops"
          }
        }
      ]
    },
    "role_summary_fr": "Détecte la formation d'un embouteillage selon le nombre de véhicules immobilisés.",
    "deployment_scopes": [
      "national",
      "enterprise"
    ],
    "partial_status": "full"
  },
  {
    "id": "tpl-illegal-parking",
    "name": "Stationnement illégal",
    "description": "Véhicule stationnaire en zone interdite",
    "category": "traffic",
    "severity": "medium",
    "supported": true,
    "definition": {
      "condition": {
        "op": "AND",
        "children": [
          {
            "op": "eq",
            "field": "event_type",
            "value": "vehicle_stopped"
          },
          {
            "op": "gt",
            "field": "duration_seconds",
            "value": 120
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "medium"
          }
        }
      ]
    },
    "role_summary_fr": "Alerte si un véhicule stationne dans une zone interdite au-delà de la durée configurée.",
    "deployment_scopes": [
      "national",
      "enterprise"
    ],
    "partial_status": "full"
  }
]
