  {
    "id": "tpl-traffic-jam",
    "name": "Embouteillage",
    "description": "Densité élevée et vitesse faible prolongée",
    "category": "traffic",
    "severity": "warning",
    "definition": {
      "condition": {
        "op": "ET",
        "children": [
          {
            "op": "gt",
            "field": "metadata.vehicle_count",
            "value": 8
          },
          {
            "op": "lt",
            "field": "metadata.avg_speed_kmh",
            "value": 10
          },
          {
            "op": "gt",
            "field": "duration_seconds",
            "value": 120
          }
        ]
      },
      "actions": [
        {
          "type": "notify",
          "config": {
            "channel": "ops"
          }
        }
      ]
    }
  },
  {
    "id": "tpl-illegal-parking",
    "name": "Stationnement illégal",
    "description": "Véhicule stationnaire en zone interdite",
    "category": "traffic",
    "severity": "medium",
    "definition": {
      "condition": {
        "op": "ET",
        "children": [
          {
            "op": "in_zone",
            "field": "zone_id",
            "value": "no-parking"
          },
          {
            "op": "gt",
            "field": "duration_seconds",
            "value": 180
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "medium"
          }
        }
      ]
    }
  }
]
