      "condition": {
        "op": "eq",
        "field": "event_type",
        "value": "sudden_stop"
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "medium"
          }
        }
      ]
    }
  },
  {
    "id": "tpl-running-person",
