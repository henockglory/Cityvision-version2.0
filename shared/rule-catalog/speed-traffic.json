[
  {
    "id": "tpl-speeding",
    "name": "Excès de vitesse véhicule",
    "description": "Véhicule dépassant le seuil de vitesse configuré",
    "category": "speed",
    "severity": "high",
    "definition": {
      "condition": {
        "op": "ET",
        "children": [
          {
            "op": "eq",
            "field": "class_name",
            "value": "car"
          },
          {
            "op": "gt",
            "field": "speed_kmh",
            "value": 50
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "high"
          }
        }
      ]
    }
  },
  {
