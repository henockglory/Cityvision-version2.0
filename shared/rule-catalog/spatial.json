[
  {
    "id": "tpl-intrusion-zone",
    "name": "Intrusion zone interdite",
    "category": "security",
    "severity": "high",
    "definition": {
      "condition": {
        "op": "AND",
        "children": [
          {
            "op": "eq",
            "field": "event_type",
            "value": "zone_enter"
          },
          {
            "op": "eq",
            "field": "zone_id",
            "value": "__ZONE__"
          },
          {
            "op": "matches_class",
            "field": "class_name",
            "value": "person"
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "high"
          }
        }
      ]
    }
  },
  {
    "id": "tpl-zone-exit",
