      "condition": {
        "op": "eq",
        "field": "event_type",
        "value": "zone_exit"
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "low"
          }
        }
      ]
    }
  },
  {
    "id": "tpl-zone-occupancy",
    "name": "Occupation zone élevée",
    "category": "spatial",
    "severity": "medium",
    "definition": {
      "condition": {
