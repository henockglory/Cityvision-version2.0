[
  {
    "id": "tpl-intrusion",
    "name": "Intrusion zone interdite",
    "category": "security",
    "severity": "high",
    "definition": {
      "condition": {
        "op": "ET",
        "children": [
          { "op": "in_zone", "field": "zone_id", "value": "restricted" },
          { "op": "eq", "field": "class_name", "value": "person" }
        ]
      },
      "actions": [{ "type": "alert", "config": { "severity": "high", "channel": "ui" } }]
    }
  },
  {
    "id": "tpl-loitering",
    "name": "Présence prolongée (loitering)",
    "category": "time",
    "severity": "medium",
    "definition": {
      "condition": { "op": "gt", "field": "duration_seconds", "value": 120 },
      "actions": [{ "type": "alert", "config": { "severity": "medium" } }],
      "window": { "start_hour": 6, "end_hour": 22, "days": ["mon", "tue", "wed", "thu", "fri", "sat", "sun"] }
    }
  },
  {
    "id": "tpl-line-cross",
    "name": "Franchissement de ligne",
    "category": "spatial",
    "severity": "medium",
    "definition": {
      "condition": { "op": "cross_line", "field": "line_id", "value": "entry-line" },
      "actions": [
        { "type": "alert", "config": { "severity": "medium" } },
        { "type": "record", "config": { "duration_sec": 30 } }
      ]
    }
  },
  {
    "id": "tpl-theft-composite",
    "name": "Vol suspect (composite)",
    "category": "composite",
    "severity": "critical",
    "definition": {
      "condition": {
        "op": "ET",
        "children": [
          { "op": "eq", "field": "event_type", "value": "zone_enter" },
          { "op": "eq", "field": "class_name", "value": "person" },
          {
            "op": "OU",
            "children": [
              { "op": "gt", "field": "duration_seconds", "value": 30 },
              { "op": "contains", "field": "metadata.behavior", "value": "concealment" }
            ]
          }
        ]
      },
      "actions": [
        { "type": "alert", "config": { "severity": "critical" } },
        { "type": "record", "config": { "duration_sec": 60 } }
      ],
      "dedup_key_fields": ["camera_id", "track_id", "event_type"]
    }
  },
  {
    "id": "tpl-abandoned-object",
    "name": "Objet abandonné",
    "category": "objects",
    "severity": "high",
    "definition": {
      "condition": {
        "op": "ET",
        "children": [
          { "op": "eq", "field": "event_type", "value": "object_appeared" },
          { "op": "gt", "field": "duration_seconds", "value": 60 }
        ]
      },
      "actions": [{ "type": "alert", "config": { "severity": "high" } }]
    }
  },
  {
    "id": "tpl-crowd-density",
    "name": "Densité de foule élevée",
    "category": "behavior",
    "severity": "warning",
    "definition": {
      "condition": { "op": "gt", "field": "metadata.density", "value": 0.005 },
      "actions": [{ "type": "notify", "config": { "channel": "ops" } }]
    }
  }
]
