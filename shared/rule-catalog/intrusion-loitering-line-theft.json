[
  {
    "id": "tpl-intrusion",
    "name": "Intrusion zone interdite",
    "category": "security",
    "severity": "high",
    "configSchema": {
      "fields": [
        {
          "key": "camera_id",
          "type": "camera",
          "required": true,
          "label": "Caméra"
        },
        {
          "key": "zone_name",
          "type": "zone",
          "required": true,
          "label": "Zone interdite",
          "hint": "Zone dessinée dans l'éditeur"
        }
      ]
    },
    "definition": {
      "condition": {
        "op": "ET",
        "children": [
          {
            "op": "in_zone",
            "field": "zone_id",
            "value": "restricted"
          },
          {
            "op": "eq",
            "field": "class_name",
            "value": "person"
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "high",
            "channel": "ui"
          }
        }
      ]
    },
    "role_summary_fr": "Alerte dès qu'une personne entre dans la zone interdite que vous avez dessinée sur la caméra.",
    "partial_status": "full"
  },
  {
    "id": "tpl-loitering",
    "name": "Présence prolongée (loitering)",
    "category": "time",
    "severity": "medium",
    "configSchema": {
      "fields": [
        {
          "key": "camera_id",
          "type": "camera",
          "required": true,
          "label": "Caméra"
        },
        {
          "key": "duration_seconds",
          "type": "number",
          "required": true,
          "label": "Durée (secondes)",
          "min": 10,
          "default": 120
        },
        {
          "key": "window",
          "type": "schedule",
          "required": false,
          "label": "Plage horaire"
        }
      ]
    },
    "definition": {
      "condition": {
        "op": "ET",
        "children": [
          {
            "op": "eq",
            "field": "event_type",
            "value": "loitering"
          },
          {
            "op": "gte",
            "field": "duration_seconds",
            "value": 120
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "medium"
          }
        }
      ],
      "window": {
        "start_hour": 6,
        "end_hour": 22,
        "days": [
          "mon",
          "tue",
          "wed",
          "thu",
          "fri",
          "sat",
          "sun"
        ]
      }
    },
    "role_summary_fr": "Signale une personne restée dans la zone au-delà de la durée configurée — suspect ou besoin d'assistance.",
    "partial_status": "full"
  },
  {
    "id": "tpl-line-cross",
    "name": "Franchissement de ligne",
    "category": "spatial",
    "severity": "medium",
    "configSchema": {
      "fields": [
        {
          "key": "camera_id",
          "type": "camera",
          "required": true,
          "label": "Caméra"
        },
        {
          "key": "line_name",
          "type": "line",
          "required": true,
          "label": "Ligne de comptage"
        }
      ]
    },
    "definition": {
      "condition": {
        "op": "cross_line",
        "field": "line_id",
        "value": "entry-line"
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "medium"
          }
        },
        {
          "type": "record",
          "config": {
            "duration_sec": 30
          }
        }
      ]
    },
    "role_summary_fr": "Alerte à chaque franchissement de la ligne virtuelle dessinée sur la caméra.",
    "partial_status": "full"
  },
  {
    "id": "tpl-theft-composite",
    "name": "Vol suspect (composite)",
    "category": "composite",
    "severity": "critical",
    "supported": true,
    "definition": {
      "condition": {
        "op": "SEQUENCE",
        "window_seconds": 300,
        "key_fields": [
          "camera_id",
          "track_id"
        ],
        "children": [
          {
            "op": "eq",
            "field": "event_type",
            "value": "zone_enter"
          },
          {
            "op": "eq",
            "field": "event_type",
            "value": "loitering"
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "critical"
          }
        },
        {
          "type": "record",
          "config": {
            "duration_sec": 60
          }
        }
      ],
      "dedup_key_fields": [
        "camera_id",
        "track_id"
      ]
    },
    "role_summary_fr": "Règle composite : alerte si une personne entre dans une zone PUIS y traîne — séquence de vol probable.",
    "partial_status": "full"
  },
  {
    "id": "tpl-abandoned-object",
    "name": "Objet abandonné",
    "category": "objects",
    "severity": "high",
    "definition": {
      "condition": {
        "op": "eq",
        "field": "event_type",
        "value": "object_abandoned"
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "high"
          }
        }
      ]
    },
    "role_summary_fr": "Signale un objet abandonné (événement object_abandoned) resté sans propriétaire après le délai configuré.",
    "partial_status": "partial_aggregate",
    "partial_reason_fr": "Dépend du détecteur abandoned analytics ; distinct de object_appeared (heuristique durée)."
  }
]
