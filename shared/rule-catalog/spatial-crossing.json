[
  {
    "id": "tpl-zone-enter",
    "name": "Entrée dans une zone",
    "description": "Franchissement d'entrée de zone virtuelle",
    "category": "spatial",
    "severity": "medium",
    "definition": {
      "condition": {
        "op": "AND",
        "children": [
          {
            "op": "eq",
            "field": "event_type",
            "value": "zone_enter"
          },
          {
            "op": "eq",
            "field": "zone_id",
            "value": "__ZONE__"
          },
          {
            "op": "matches_class",
            "field": "class_name",
            "value": "person"
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "medium"
          }
        }
      ]
    },
    "role_summary_fr": "Alerte au premier passage d'un objet dans la zone. Utile pour compter les entrées ou détecter un accès.",
    "deployment_scopes": [
      "national",
      "enterprise",
      "domestic"
    ],
    "partial_status": "full"
  },
