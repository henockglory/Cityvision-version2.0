[
  {
    "id": "tpl-traffic-pipeline",
    "name": "Pipeline voiture → plaque + vitesse",
    "category": "road-enforcement",
    "severity": "high",
    "supported": true,
    "tutorial": {
      "legend": "Détection → Enrichissement OCR/vitesse → Condition → Alerte + preuves",
      "steps": [
        "Dessinez une zone sur la voie",
        "Filtrez sur la classe « voiture »",
        "Le pipeline active OCR plaque et estimation vitesse dans la zone",
        "Définissez la condition (ex. vitesse > 50 km/h)",
        "Configurez preuves et notifications"
      ]
    },
    "definition": {
      "priority": 150,
      "suppress_lower": true,
      "pipeline": {
        "trigger": { "event_type": "zone_presence", "class_filter": "car" },
        "stages": [
          { "capability": "plate_ocr", "budget": "high" },
          { "capability": "speed_estimate" },
          { "capability": "evidence_capture" }
        ]
      },
      "condition": {
        "op": "AND",
        "children": [
          { "op": "eq", "field": "event_type", "value": "vehicle_corridor" },
          { "op": "gt", "field": "speed_kmh", "value": 50 }
        ]
      },
      "actions": [
        { "type": "alert", "config": { "severity": "high" } },
        { "type": "record", "config": {} }
      ],
      "bindings": {
        "template_id": "tpl-traffic-corridor",
        "class_filter": "car"
      }
    }
  },
  {
    "id": "tpl-speeding-premium",
