[
  {
    "id": "tpl-crowd-panic",
    "name": "Panique de foule",
    "description": "Dispersion rapide et soudaine d'un groupe",
    "category": "crowd",
    "severity": "critical",
    "supported": true,
    "definition": {
      "condition": {
        "op": "eq",
        "field": "event_type",
        "value": "crowd_panic"
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "critical"
          }
        },
        {
          "type": "record",
          "config": {
            "duration_sec": 120
          }
        }
      ]
    },
    "role_summary_fr": "Détecte une dispersion soudaine et rapide d'un groupe — signal fort de panique ou d'incident grave.",
    "partial_status": "full"
  },
  {
    "id": "tpl-group-formation",
    "name": "Attroupement suspect",
    "description": "Formation rapide d'un groupe dense",
    "category": "crowd",
    "severity": "high",
    "definition": {
      "condition": {
        "op": "ET",
        "children": [
          {
            "op": "eq",
            "field": "event_type",
            "value": "crowd_gathering"
          },
          {
            "op": "gte",
            "field": "metadata.neighbor_count",
            "value": 5
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "high"
          }
        }
      ]
    },
    "role_summary_fr": "Signale la formation rapide d'un attroupement dense dépassant le seuil de personnes configuré.",
    "partial_status": "partial_aggregate",
    "partial_reason_fr": "Attroupement détecté via crowd_gathering — le seuil neighbor_count >= 5 peut nécessiter ajustement selon densité habituelle"
  },
  {
    "id": "tpl-fight",
    "name": "Bagarre probable",
    "description": "Mouvements violents multi-personnes",
    "category": "incident",
    "severity": "critical",
    "supported": true,
    "definition": {
      "condition": {
        "op": "eq",
        "field": "event_type",
        "value": "fight_detected"
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "critical"
          }
        },
        {
          "type": "record",
          "config": {
            "duration_sec": 90
          }
        }
      ]
    },
    "role_summary_fr": "Alerte critique si des mouvements violents multi-personnes sont détectés sur la scène.",
    "partial_status": "full"
  },
  {
    "id": "tpl-accident",
    "name": "Accident routier probable",
    "description": "Arrêt brutal + véhicules multiples + absence de mouvement",
    "category": "composite",
    "severity": "critical",
    "supported": true,
    "definition": {
      "condition": {
        "op": "SEQUENCE",
        "window_seconds": 30,
        "children": [
          {
            "op": "eq",
            "field": "event_type",
            "value": "sudden_stop"
          },
          {
            "op": "eq",
            "field": "event_type",
            "value": "vehicle_stopped"
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "critical"
          }
        },
        {
          "type": "incident",
          "config": {}
        }
      ]
    },
    "role_summary_fr": "Détecte un enchaînement arrêt brutal → véhicule immobilisé caractéristique d'un accident routier.",
    "partial_status": "full"
  },
  {
    "id": "tpl-vandalism",
    "name": "Vandalisme suspect",
    "description": "Groupe + activité rapide + dispersion",
    "category": "composite",
    "severity": "critical",
    "supported": true,
    "definition": {
      "condition": {
        "op": "SEQUENCE",
        "window_seconds": 60,
        "key_fields": [
          "camera_id"
        ],
        "children": [
          {
            "op": "eq",
            "field": "event_type",
            "value": "crowd_gathering"
          },
          {
            "op": "eq",
            "field": "event_type",
            "value": "running"
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "critical"
          }
        }
      ],
      "dedup_key_fields": [
        "camera_id"
      ]
    },
    "role_summary_fr": "Alerte si un attroupement suivi d'une activité rapide (dispersion) est détecté — séquence de vandalisme.",
    "partial_status": "full"
  },
  {
    "id": "tpl-face-watchlist",
    "name": "Personne liste noire",
    "description": "Visage correspondant à la watchlist",
    "category": "identity",
    "severity": "critical",
    "definition": {
      "condition": {
        "op": "eq",
        "field": "event_type",
        "value": "face_watchlist_match"
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "critical"
          }
        },
        {
          "type": "notify",
          "config": {
            "channel": "security"
          }
        }
      ]
    },
    "role_summary_fr": "Alerte critique si un visage correspondant à la liste de surveillance est reconnu par la caméra.",
    "partial_status": "requires_face_ai",
    "partial_reason_fr": "Nécessite le module InsightFace (non installé par défaut)"
  },
  {
    "id": "tpl-plate-unknown",
    "name": "Plaque non enregistrée",
    "description": "Véhicule avec plaque inconnue en zone restreinte",
    "category": "identity",
    "severity": "high",
    "configSchema": {
      "fields": [
        {
          "key": "camera_id",
          "type": "camera",
          "required": true,
          "label": "Caméra"
        }
      ]
    },
    "definition": {
      "condition": {
        "op": "eq",
        "field": "event_type",
        "value": "plate_unknown"
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "high"
          }
        }
      ]
    },
    "role_summary_fr": "Signale un véhicule dont la plaque d'immatriculation n'est pas enregistrée dans la base.",
    "partial_status": "requires_ocr",
    "partial_reason_fr": "Nécessite le module PaddleOCR (non installé par défaut)"
  },
  {
    "id": "tpl-industrial-intrusion",
    "name": "Intrusion site industriel",
    "description": "Présence non autorisée en zone machine",
    "category": "industrial",
    "severity": "critical",
    "definition": {
      "condition": {
        "op": "ET",
        "children": [
          {
            "op": "in_zone",
            "field": "zone_id",
            "value": "machine-zone"
          },
          {
            "op": "eq",
            "field": "class_name",
            "value": "person"
          }
        ]
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "critical"
          }
        }
      ]
    },
    "role_summary_fr": "Alerte si une personne pénètre dans une zone machine ou dangereuse sur site industriel.",
    "partial_status": "full"
  }
]
