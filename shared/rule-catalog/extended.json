    "id": "tpl-intrusion-after-hours",
    "name": "Intrusion hors horaires",
    "category": "security",
    "severity": "critical",
    "definition": {
      "condition": {
        "op": "AND",
        "children": [
          {
            "op": "eq",
            "field": "event_type",
            "value": "zone_enter"
          },
          {
            "op": "eq",
            "field": "class",
            "value": "person"
          }
        ]
      },
      "window": {
        "start_hour": 22,
        "end_hour": 6
      },
      "actions": [
        {
          "type": "alert",
          "config": {
            "severity": "critical"
          }
        }
      ]
    }
  },
