{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://citevision.local/schemas/rule.json",
  "title": "Rule",
  "description": "Declarative rule definition with ET/OU/NON condition trees",
  "type": "object",
  "required": ["rule_id", "name", "enabled", "condition", "actions"],
  "properties": {
    "rule_id": { "type": "string" },
    "name": { "type": "string" },
    "camera_id": { "type": "string" },
    "enabled": { "type": "boolean" },
    "priority": { "type": "integer", "minimum": 0 },
    "condition": { "$ref": "#/$defs/conditionNode" },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "enum": ["alert", "webhook", "record", "notify"] },
          "config": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "window": {
      "type": "object",
      "properties": {
        "start_hour": { "type": "integer", "minimum": 0, "maximum": 23 },
        "end_hour": { "type": "integer", "minimum": 0, "maximum": 23 },
        "days": {
          "type": "array",
          "items": { "type": "string", "enum": ["mon", "tue", "wed", "thu", "fri", "sat", "sun"] }
        }
      }
    },
    "dedup_key_fields": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "conditionNode": {
      "type": "object",
      "required": ["op"],
      "properties": {
        "op": {
          "type": "string",
          "enum": ["ET", "OU", "NON", "eq", "gt", "lt", "contains", "in_zone", "cross_line"]
        },
        "field": { "type": "string" },
        "value": {},
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/conditionNode" }
        }
      }
    }
  },
  "additionalProperties": false
}
