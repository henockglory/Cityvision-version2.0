{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://citevision.local/schemas/event.json",
  "title": "Event",
  "description": "Analytics event generated from detections and rules",
  "type": "object",
  "required": ["event_id", "camera_id", "event_type", "timestamp", "severity"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "camera_id": { "type": "string" },
    "event_type": {
      "type": "string"
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "severity": { "type": "string", "enum": ["info", "warning", "critical"] },
    "track_id": { "type": "integer", "minimum": -1 },
    "zone_id": { "type": "string" },
    "line_id": { "type": "string" },
    "direction": { "type": "string", "enum": ["in", "out", "left", "right", "unknown"] },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "metadata": { "type": "object", "additionalProperties": true },
    "evidence": {
      "type": "object",
      "properties": {
        "package": { "$ref": "evidence.json" },
        "pending": { "type": "boolean" }
      }
    },
    "class_name": { "type": "string" },
    "confidence": { "type": "number" }
  },
  "additionalProperties": true
}
